# ============================================================================
# RUNTIME & USER DATA (Generated after first run - DO NOT COMMIT)
# ============================================================================
config.json
token.json
war_name_aliases.json
.easyocr/

# Keep empty folder structure in Git, but ignore user testing data inside them
War Screenshots/*
!War Screenshots/.gitkeep
War Records/*
!War Records/.gitkeep
debug_gw_parser/*
!debug_gw_parser/.gitkeep

# Temp files created during export
__tmp_export_*.pdf
~$*.xlsx

# ============================================================================
# SECRETS & LOCAL DEBUG (Do NOT commit personal keys/files)
# ============================================================================
e7_keys.log
API Packets/
Zodiac GW Spreadsheet.xlsx
client_secret.json

# NOTE: client_secret.json is INTENTIONALLY NOT ignored.
# Since users are using your shared OAuth, it MUST be committed to the repo 
# so it gets included in the GitHub Release ZIP file.

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================================================
