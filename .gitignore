# Ignore API Packets folder
API Packets/
e7_keys.log

# Ignore ALL files inside War Records (including subfolders)
War Records/**/*
# But keep the folder itself by allowing this specific file
!War Records/.gitkeep

# Ignore ALL files inside War Screenshots (including subfolders)
War Screenshots/**/*
# But keep the folder itself by allowing this specific file
!War Screenshots/.gitkeep

# Ignore Json (user-specific config, tokens, secrets, aliases)
*.json

# Ignore Spreadsheets
*.xlsx

# Ignore old script
zodiac_war_tools.py

# Ignore debug output
debug_gw_parser/

# Ignore VS Code workspace settings
.vscode/
